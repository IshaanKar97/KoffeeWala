# ── Phase 1 — Notion sync (Netlify functions, server-side) ──────────────────
# Notion integration secret. Used ONLY by the Netlify serverless functions.
# Local dev: copy this file to `.env` and fill in, then run `netlify dev`.
# Production: set NOTION_TOKEN in Netlify → Site settings → Environment variables.
NOTION_TOKEN=
# Optional: override the Logbook database id.
# NOTION_LOGBOOK_DB_ID=e746a40f6a324aff98cabb8d72fbe8ae

# ── Phase 2 — Supabase (recipe data + auth) ─────────────────────────────────
# Project URL and anon (public) key from Supabase → Project Settings → API.
# The anon key is publishable and safe in the client; Row-Level Security
# enforces per-user access. (Do NOT put the service_role key here.)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
